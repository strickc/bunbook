{
  "name": "bunbook",
  "version": "0.1.0",
  "description": "A Jupyter-like notebook system using Markdown and Bun",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/server/index.ts examples/advanced_test.bunbk.md",
    "check": "tsc --noEmit"
  },
  "bin": {
    "bunbook": "src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bun-types": "latest",
    "codemirror": "^6.0.1",
    "@codemirror/view": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "markdown-it": "^14.1.0"
  }
}
