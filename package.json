{
  "name": "bunbook",
  "version": "0.1.0",
  "description": "A Jupyter-like notebook system using Markdown and Bun",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/server/index.ts examples/advanced_test.bunbk.md",
    "check": "tsc --noEmit"
  },
  "bin": {
    "bunbook": "src/cli.ts"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@codemirror/autocomplete": "^6.18.1",
    "@codemirror/lint": "^6.8.1",
    "codemirror": "^6.0.2",
    "markdown-it": "^14.1.1",
    "typescript": "^5.3.3"
  }
}
